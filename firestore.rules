rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Website đọc công khai; chỉ admin đã đăng nhập mới được ghi
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
